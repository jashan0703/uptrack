# Appwrite configuration
# Copy this file to .env.local and fill in the values from your Appwrite Cloud project.
# .env.local is gitignored and must NEVER be committed.

# --- Public (exposed to the browser) ---
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_APPWRITE_DATABASE_ID=uptrack

# --- Server only (NEVER prefix with NEXT_PUBLIC, never sent to the client) ---
# Create an API key in the Appwrite console with scopes:
#   users.read, users.write, databases.read, databases.write,
#   collections.read, collections.write, attributes.read, attributes.write,
#   indexes.read, indexes.write, documents.read, documents.write
APPWRITE_API_KEY=your_server_api_key_here

# Default password assigned to seeded demo accounts (change before seeding).
SEED_DEFAULT_PASSWORD=ChangeMe123!

# Optional: enables a "Login as Admin (demo)" button on the sign-in modal.
# Leave blank to hide the button. Only use a demo/seed account here — never a
# real production credential, since NEXT_PUBLIC_ vars are exposed to the browser.
NEXT_PUBLIC_DEMO_ADMIN_EMAIL=
NEXT_PUBLIC_DEMO_ADMIN_PASSWORD=
